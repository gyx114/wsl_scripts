#!/bin/bash
if [ -z "$1" ]; then
    echo "用法: play <文件名或路径>"
    exit 1
fi
file_path=""
if [ -f "$1" ]; then
    file_path=$(realpath "$1")
fi
if [ -z "$file_path" ]; then
    IFS=':' read -ra path_dirs <<< "$PATH"
    for dir in "${path_dirs[@]}"; do
        if [ -f "$dir/$1" ]; then
            file_path="$dir/$1"
            break
        fi
    done
fi
if [ -z "$file_path" ]; then
    desktop_dir="/mnt/c/Users/guany/Desktop"
    if [ -f "$desktop_dir/$1" ]; then
        file_path="$desktop_dir/$1"
    fi
fi
if [ -z "$file_path" ]; then
    echo "❌ 找不到文件: $1"
    echo "搜索路径: 当前目录, PATH, 桌面"
    exit 1
fi
win_path=$(wslpath -w "$file_path")
/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -Command "Start-Process '$win_path'"
echo "✅ 已打开: $file_path"
